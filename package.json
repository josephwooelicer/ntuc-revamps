{
  "name": "ntuc-revamps",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web-platform",
    "worker-service"
  ],
  "scripts": {
    "setup": "bash ./scripts/setup-dev.sh",
    "db:init": "npm --workspace worker-service run db:init",
    "db:status": "npm --workspace worker-service run db:status",
    "dev": "bash ./scripts/start-local.sh",
    "dev:web": "npm --workspace web-platform run dev",
    "dev:worker": "npm --workspace worker-service run dev",
    "health": "bash ./scripts/health-check.sh",
    "deps:down": "bash ./scripts/stop-local.sh",
    "singstat:download-all": "node ./scripts/download-singstat-reports.mjs"
  }
}
